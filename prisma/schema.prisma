generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                String                 @id @default(cuid())
  email             String                 @unique
  passwordHash      String?
  name              String?
  customerType      CustomerType           @default(B2C)
  status            AccountStatus          @default(PENDING_EMAIL)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  buyerType         BuyerType              @default(PERSON)
  city              String?
  companyName       String?
  ico               String?
  phone             String?
  volume            VolumeTier             @default(SMALL)
  dic               String?
  firstName         String?
  houseNumber       String?
  lastName          String?
  street            String?
  zip               String?
  accounts          Account[]
  cart              Cart?
  emailVerification EmailVerificationCode?
  inquiries         Inquiry[]
  sessions          Session[]
  invoiceStreet       String?
  invoiceHouseNumber  String?
  invoiceCity         String?
  invoiceZip          String?
}

model Product {
  id           String             @id @default(cuid())
  sku          String?            @unique
  name         String
  description  String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  imageUrl     String?
  collection   ProductCollection?
  slug         String             @unique
  cartItems    CartItem[]
  inquiryItems InquiryItem[]
  prices       Price[]
}

model Price {
  id           String       @id @default(cuid())
  productId    String
  customerType CustomerType
  amountCzk    Int
  currency     String       @default("CZK")
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, customerType])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  decor     String?
  felt      String?
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, decor, felt])
}

model Inquiry {
  id                   String        @id @default(cuid())
  userId               String
  status               InquiryStatus @default(NEW)
  note                 String?
  customerTypeSnapshot CustomerType
  statusSnapshot       AccountStatus
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  orderNumber          Int           @unique
  user                 User          @relation(fields: [userId], references: [id])
  items                InquiryItem[]
}

model InquiryItem {
  id                   String  @id @default(cuid())
  inquiryId            String
  productId            String
  skuSnapshot          String?
  nameSnapshot         String
  quantity             Int
  unitPriceCzkSnapshot Int?
  currencySnapshot     String  @default("CZK")
  decorSnapshot        String?
  feltSnapshot         String?
  inquiry              Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product              Product @relation(fields: [productId], references: [id])
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
}

enum CustomerType {
  B2C
  B2B_SMALL
  B2B_BIG
}

enum AccountStatus {
  ACTIVE
  PENDING
  DISABLED
  PENDING_EMAIL
}

enum BuyerType {
  PERSON
  COMPANY
}

enum VolumeTier {
  SMALL
  MEDIUM
  LARGE
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELED
}

enum ProductCollection {
  CLASSIC
  PREMIUM
  SPAZIO
  MODULLO
  RIFFCELLO
}
