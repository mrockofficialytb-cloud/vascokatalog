generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum CustomerType {
  B2C
  B2B_SMALL
  B2B_BIG
}

enum AccountStatus {
  // NOVĚ: účet vytvořen, ale e-mail ještě nebyl ověřen kódem
  PENDING_EMAIL

  // už máš:
  ACTIVE
  PENDING
  DISABLED
}

enum BuyerType {
  PERSON
  COMPANY
}

enum VolumeTier {
  SMALL
  MEDIUM
  LARGE
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String?
  name         String?
  customerType CustomerType  @default(B2C)

  // ✅ změna: default dáme PENDING_EMAIL (anti-spam)
  status       AccountStatus @default(PENDING_EMAIL)

  // Kontakty
  firstName    String?
  lastName     String?
  phone        String?

  // Adresa
  street       String?
  houseNumber  String?
  city         String?
  zip          String?

  // Segmentace
  buyerType    BuyerType     @default(PERSON)
  volume       VolumeTier    @default(SMALL)

  // Firma
  companyName  String?
  ico          String?
  dic          String?

  // ✅ NOVĚ: e-mail ověřovací kód (1 aktivní kód na uživatele)
  emailVerification EmailVerificationCode?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  accounts     Account[]
  sessions     Session[]
  cart         Cart?
  inquiries    Inquiry[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String?  @unique
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)

  prices      Price[]
  imageUrl    String?
  collection  ProductCollection?

  cartItems    CartItem[]
  inquiryItems InquiryItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Price {
  id           String       @id @default(cuid())
  productId    String
  customerType CustomerType
  amountCzk    Int
  currency     String       @default("CZK")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, customerType])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELED
}

enum ProductCollection {
  CLASSIC
  PREMIUM
  SPAZIO
  MODULLO
  RIFFCELLO
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)

    decor     String?
  felt      String?
  
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, decor, felt])
}

model Inquiry {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  status               InquiryStatus @default(NEW)
  note                 String?
  customerTypeSnapshot CustomerType
  statusSnapshot       AccountStatus

  items                InquiryItem[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model InquiryItem {
  id                   String   @id @default(cuid())
  inquiryId            String
  productId            String

  skuSnapshot          String?
  nameSnapshot         String
  quantity             Int

  decorSnapshot        String?
  feltSnapshot         String?

  unitPriceCzkSnapshot Int?
  currencySnapshot     String   @default("CZK")

  inquiry              Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

//
// ✅ NOVÝ MODEL: Ověření e-mailu kódem (anti-spam)
// - držíme HASH kódu (ne samotný kód)
// - expires = platnost (např. 15 min)
// - attempts = počítadlo pokusů
//
model EmailVerificationCode {
  id          String   @id @default(cuid())
  userId      String   @unique
  codeHash    String
  expiresAt   DateTime
  attempts    Int      @default(0)
  lastSentAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([expiresAt])
}